# แม่แบบ env ฝั่ง server — คัดลอกเป็น .env แล้วใส่ค่าจริง (อย่า commit .env)

# Database (Supabase PostgreSQL)
DATABASE_URL=

# JWT secret (บังคับมี — ไม่งั้น server ไม่ start)
SECRET=

# Email ใบแจ้งหนี้ (M6) — Gmail App Password
MAIL_USER=
MAIL_PASS=

# PromptPay + Supabase Storage สลิป (M7)
PROMPTPAY_ID=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Social Login (M10c) — ดูวิธีขอใน docs/SOCIAL_LOGIN_SETUP.md
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
